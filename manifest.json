{
  "manifest_version": 3,
  "name": "小红书选题器",
  "description": "采集小红书爆款笔记的封面、标题、关键词和选题，按栏目本地保存为表格。",
  "version": "0.2.16",
  "action": {
    "default_title": "采集选题",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "options_page": "dashboard.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["activeTab", "alarms", "contextMenus", "notifications", "sidePanel", "storage", "scripting", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://*.xiaohongshu.com/*",
    "https://*.xhscdn.com/*",
    "https://api.deepseek.com/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
